<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ 'gift_cards.issued.title' | t: value: gift_card.initial_value | money_without_trailing_zeros, shop: shop.name }}</title>
    {{ content_for_header }}
    {{- 'vite-theme.css' | asset_url | stylesheet_tag -}}
  </head>
  <body class="template-giftcard">

    <div class="gift-card">
      <h1>{{ shop.name }}</h1>
      <p>{{ 'gift_cards.issued.subtext' | t }}</p>

      <div class="gift-card__price">
        <p>
          {%- if gift_card.balance != gift_card.initial_value -%}
            <span>{{ 'gift_cards.issued.remaining_html' | t: balance: gift_card.balance | money }}</span>
          {%- endif -%}
          <strong>{{ gift_card.initial_value | money_without_trailing_zeros }}</strong>
        </p>
      </div>

      {%- unless gift_card.enabled -%}
        <p>{{ 'gift_cards.issued.disabled' | t }}</p>
      {%- endunless -%}
      {%- if gift_card.expired -%}
        <p>{{ 'gift_cards.issued.expired' | t: expiry: gift_card.expires_on | date: format: 'basic' }}</p>
      {%- endif -%}

      <div class="gift-card__code">
        <input
          type="text"
          class="gift-card__code-input"
          value="{{ gift_card.code | format_code }}"
          aria-label="{{ 'gift_cards.issued.gift_card_code' | t }}"
          readonly
        >
      </div>

      <div id="QrCode" data-identifier="{{ gift_card.qr_identifier }}"></div>
    </div>

    <script src="{{ 'vite-theme.js' | asset_url }}" defer></script>
    {{ 'gift-card/qr.js' | shopify_asset_url | script_tag }}
  </body>
</html>
