<header class="masthead masthead">
  <svg
    class="svg svg--berry-logo"
    viewBox="0 0 2354 2329"
    height="50"
    role="presentation"
    aria-labelledby="#berry-logo-label"
  >
    <title id="berry-logo-label"></title>
    <use href="#berry-logo"></use>
  </svg>

  <svg
    class="svg svg--berry-logo"
    viewBox="0 0 2084 792"
    height="50"
    role="presentation"
    aria-labelledby="#berry-logo-label"
  >
    <title id="berry-logo-label"></title>
    <use href="#iou-logo"></use>
  </svg>

  <svg class="svg svg--arrow" viewBox="0 0 735 1973" height="50" role="presentation" aria-labelledby="#arrow-label">
    <title id="arrow-label"></title>
    <use href="#arrow"></use>
  </svg>

  <svg class="svg svg--mail" viewBox="0 0 3125 2233" height="50" role="presentation">

    <use href="#mail"></use>
  </svg>

  <div class="masthead__inner">
    <a href="{{ routes.root_url }}" class="masthead__logo">
      {%- if section.settings.logo != blank -%}
        {{
          section.settings.logo
          | image_url: width: 300
          | image_tag: loading: 'eager', fetchpriority: 'high', alt: section.settings.logo.alt
          | default: shop.name
        }}
      {%- else -%}
        {{ shop.name }}
      {%- endif -%}
    </a>

    <nav class="site-nav" aria-label="{{ 'accessibility.main_menu' | t }}">
      {%- if section.settings.menu != blank -%}
        <ul class="site-nav__list" role="list">
          {%- for link in section.settings.menu.links -%}
            <li>
              <a
                href="{{ link.url }}"
                {% if link.active %}
                  aria-current="page"
                {% endif %}
              >
                {{ link.title }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </nav>

    <div class="masthead__icons">
      {%- if shop.customer_accounts_enabled -%}
        <a href="{{ routes.account_url }}" aria-label="{{ 'customer.account.title' | t }}">
          {% render 'icon-account' %}
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" aria-label="{{ 'cart.title' | t }}">
        {% render 'icon-cart' %}
        <span class="cart-count">{{ cart.item_count }}</span>
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "class": "section-header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "Menu"
    }
  ]
}
{% endschema %}
