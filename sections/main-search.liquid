<section class="main-search" {{ section.shopify_attributes }}>
  <h1>{{ 'general.search.title' | t }}</h1>

  {%- form 'search', action: routes.search_url -%}
    <label for="SearchInput" class="visually-hidden">{{ 'general.search.placeholder' | t }}</label>
    <input
      id="SearchInput"
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="{{ 'general.search.placeholder' | t }}"
    >
    <input type="hidden" name="type" value="{{ section.settings.search_type }}">
    <button type="submit">{{ 'general.search.search' | t }}</button>
  {%- endform -%}

  {%- if search.performed -%}
    <p>{{ 'general.search.results_with_count' | t: terms: search.terms, count: search.results_count }}</p>
    {%- if search.results_count > 0 -%}
      {%- paginate search.results by 24 -%}
        <ul role="list">
          {%- for result in search.results -%}
            <li>
              <a href="{{ result.url }}">{{ result.title }}</a>
            </li>
          {%- endfor -%}
        </ul>
        {%- if paginate.pages > 1 -%}
          {% render 'pagination', paginate: paginate %}
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <p>{{ 'general.search.no_results' | t: terms: search.terms }}</p>
    {%- endif -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Search",
  "tag": "section",
  "class": "section-main-search",
  "settings": [
    {
      "type": "select",
      "id": "search_type",
      "label": "Search type",
      "options": [
        { "value": "product,page,article", "label": "Products, pages, articles" },
        { "value": "product", "label": "Products only" }
      ],
      "default": "product,page,article"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Search"
    }
  ]
}
{% endschema %}
