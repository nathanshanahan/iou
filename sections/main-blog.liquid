<section class="main-blog" {{ section.shopify_attributes }}>
  <h1>{{ blog.title }}</h1>

  {%- paginate blog.articles by section.settings.articles_per_page -%}
    <ul class="article-grid" role="list">
      {%- for article in blog.articles -%}
        <li>
          <a href="{{ article.url }}">
            {%- if article.image -%}
              {{
                article.image
                | image_url: width: 600
                | image_tag: loading: 'lazy', alt: article.image.alt | default: article.title, widths: '300, 600'
              }}
            {%- endif -%}
            <h2>{{ article.title }}</h2>
            <p>{{ article.published_at | time_tag: format: 'date' }}</p>
            {%- if article.excerpt != blank -%}
              <p>{{ article.excerpt }}</p>
            {%- endif -%}
          </a>
        </li>
      {%- endfor -%}
    </ul>

    {%- if paginate.pages > 1 -%}
      {% render 'pagination', paginate: paginate %}
    {%- endif -%}
  {%- endpaginate -%}
</section>

{% schema %}
{
  "name": "Blog",
  "tag": "section",
  "class": "section-main-blog",
  "settings": [
    {
      "type": "range",
      "id": "articles_per_page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Articles per page"
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ],
  "presets": [
    {
      "name": "Blog"
    }
  ]
}
{% endschema %}
