{%- if section.settings.text != blank -%}
  {%- assign repeat_count = section.settings.repeat_count | default: 6 -%}

  {%- capture announcement_sequence -%}
    {%- for index in (1..repeat_count) -%}
      <span class="announcement-bar__item">{{ section.settings.text | escape }}</span>
    {%- endfor -%}
  {%- endcapture -%}

  <section
    class="announcement-bar"
    data-announcement-bar
    style="--announcement-speed-desktop: {{ section.settings.speed_desktop }}s; --announcement-speed-mobile: {{ section.settings.speed_mobile }}s;"
  >
    {%- if section.settings.link != blank -%}
      <a class="announcement-bar__link" href="{{ section.settings.link }}">
        <span class="announcement-bar__track">
          <span class="announcement-bar__sequence">
            {{ announcement_sequence }}
          </span>
          <span class="announcement-bar__sequence" aria-hidden="true">
            {{ announcement_sequence }}
          </span>
        </span>
      </a>
    {%- else -%}
      <div class="announcement-bar__content">
        <span class="announcement-bar__track">
          <span class="announcement-bar__sequence">
            {{ announcement_sequence }}
          </span>
          <span class="announcement-bar__sequence" aria-hidden="true">
            {{ announcement_sequence }}
          </span>
        </span>
      </div>
    {%- endif -%}
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "tag": "div",
  "class": "section-announcement-bar",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "range",
      "id": "repeat_count",
      "label": "Text repeats per sequence",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "range",
      "id": "speed_desktop",
      "label": "Desktop speed",
      "min": 5,
      "max": 40,
      "step": 1,
      "default": 18,
      "unit": "s"
    },
    {
      "type": "range",
      "id": "speed_mobile",
      "label": "Mobile speed",
      "min": 5,
      "max": 40,
      "step": 1,
      "default": 22,
      "unit": "s"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}