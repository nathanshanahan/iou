{%- liquid
  assign form_id = section.id | append: '_contact_form'
  assign form_class = 'contact-form'
-%}

<section class="contact-form-section {{ section.settings.section_class }}" id="section-{{ section.id }}">
  <div class="contact-form-section__container">
    {%- if section.settings.heading != blank -%}
      <div class="contact-form__header">
        <h2 class="contact-form__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="contact-form__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- form 'contact', id: form_id, class: form_class -%}
      {%- if form.posted_successfully? -%}
        <div class="contact-form__success" role="status">
          {{ section.settings.success_message | default: 'Thank you! Your message has been sent successfully.' }}
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="contact-form__errors" role="alert">
          <h3 class="contact-form__errors-heading">{{ 'contact.form.error_heading' | t | default: 'There were some errors with your submission:' }}</h3>
          <ul class="contact-form__errors-list">
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  {{ form.errors.messages[field] }}
                {%- else -%}
                  {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="contact-form__fields">
        {%- for block in section.blocks -%}
          {%- liquid
            assign field_id = block.id
            assign field_name = block.settings.field_name
            assign field_label = block.settings.label
            assign field_placeholder = block.settings.placeholder
            assign field_required = block.settings.required
            assign field_class = 'contact-form__field'
            
            if block.settings.field_width != blank
              assign field_class = field_class | append: ' contact-form__field--' | append: block.settings.field_width
            endif
            
            if field_required
              assign field_class = field_class | append: ' contact-form__field--required'
            endif
          -%}

          <div class="{{ field_class }}" {{ block.shopify_attributes }}>
            {%- case block.type -%}
              
              {%- when 'text_input' -%}
                <label for="{{ field_id }}" class="contact-form__label">
                  {{ field_label }}
                  {%- if field_required -%}<span class="contact-form__required">*</span>{%- endif -%}
                </label>
                <input
                  type="text"
                  id="{{ field_id }}"
                  name="contact[{{ field_name }}]"
                  class="contact-form__input"
                  placeholder="{{ field_placeholder }}"
                  value="{{ form[field_name] }}"
                  {% if field_required %}required{% endif %}
                  {% if block.settings.autocomplete != blank %}autocomplete="{{ block.settings.autocomplete }}"{% endif %}
                >

              {%- when 'email_input' -%}
                <label for="{{ field_id }}" class="contact-form__label">
                  {{ field_label }}
                  {%- if field_required -%}<span class="contact-form__required">*</span>{%- endif -%}
                </label>
                <input
                  type="email"
                  id="{{ field_id }}"
                  name="contact[email]"
                  class="contact-form__input"
                  placeholder="{{ field_placeholder }}"
                  value="{{ form.email }}"
                  {% if field_required %}required{% endif %}
                  autocomplete="email"
                >

              {%- when 'phone_input' -%}
                <label for="{{ field_id }}" class="contact-form__label">
                  {{ field_label }}
                  {%- if field_required -%}<span class="contact-form__required">*</span>{%- endif -%}
                </label>
                <input
                  type="tel"
                  id="{{ field_id }}"
                  name="contact[{{ field_name }}]"
                  class="contact-form__input"
                  placeholder="{{ field_placeholder }}"
                  value="{{ form[field_name] }}"
                  {% if field_required %}required{% endif %}
                  autocomplete="tel"
                >

              {%- when 'textarea' -%}
                <label for="{{ field_id }}" class="contact-form__label">
                  {{ field_label }}
                  {%- if field_required -%}<span class="contact-form__required">*</span>{%- endif -%}
                </label>
                <textarea
                  id="{{ field_id }}"
                  name="contact[{{ field_name }}]"
                  class="contact-form__textarea"
                  placeholder="{{ field_placeholder }}"
                  rows="{{ block.settings.rows | default: 4 }}"
                  {% if field_required %}required{% endif %}
                >{{ form[field_name] }}</textarea>

              {%- when 'select' -%}
                <label for="{{ field_id }}" class="contact-form__label">
                  {{ field_label }}
                  {%- if field_required -%}<span class="contact-form__required">*</span>{%- endif -%}
                </label>
                <select
                  id="{{ field_id }}"
                  name="contact[{{ field_name }}]"
                  class="contact-form__select"
                  {% if field_required %}required{% endif %}
                >
                  <option value="">{{ block.settings.default_option | default: 'Please select...' }}</option>
                  {%- assign options = block.settings.options | split: ',' -%}
                  {%- for option in options -%}
                    {%- assign option_trimmed = option | strip -%}
                    <option value="{{ option_trimmed }}" {% if form[field_name] == option_trimmed %}selected{% endif %}>
                      {{ option_trimmed }}
                    </option>
                  {%- endfor -%}
                </select>

              {%- when 'checkbox' -%}
                <div class="contact-form__checkbox-wrapper">
                  <input
                    type="checkbox"
                    id="{{ field_id }}"
                    name="contact[{{ field_name }}]"
                    class="contact-form__checkbox"
                    value="yes"
                    {% if form[field_name] == 'yes' %}checked{% endif %}
                    {% if field_required %}required{% endif %}
                  >
                  <label for="{{ field_id }}" class="contact-form__checkbox-label">
                    {{ field_label }}
                    {%- if field_required -%}<span class="contact-form__required">*</span>{%- endif -%}
                  </label>
                </div>

              {%- when 'radio' -%}
                <fieldset class="contact-form__radio-group">
                  <legend class="contact-form__label">
                    {{ field_label }}
                    {%- if field_required -%}<span class="contact-form__required">*</span>{%- endif -%}
                  </legend>
                  {%- assign options = block.settings.options | split: ',' -%}
                  {%- for option in options -%}
                    {%- assign option_trimmed = option | strip -%}
                    {%- assign radio_id = field_id | append: '_' | append: forloop.index -%}
                    <div class="contact-form__radio-wrapper">
                      <input
                        type="radio"
                        id="{{ radio_id }}"
                        name="contact[{{ field_name }}]"
                        class="contact-form__radio"
                        value="{{ option_trimmed }}"
                        {% if form[field_name] == option_trimmed %}checked{% endif %}
                        {% if field_required %}required{% endif %}
                      >
                      <label for="{{ radio_id }}" class="contact-form__radio-label">{{ option_trimmed }}</label>
                    </div>
                  {%- endfor -%}
                </fieldset>

              {%- when 'hidden' -%}
                <input
                  type="hidden"
                  name="contact[{{ field_name }}]"
                  value="{{ block.settings.value }}"
                >

              {%- when 'spacer' -%}
                <div class="contact-form__spacer" style="height: {{ block.settings.height | default: 20 }}px;"></div>

              {%- when 'html' -%}
                <div class="contact-form__html">
                  {{ block.settings.html }}
                </div>

            {%- endcase -%}
          </div>
        {%- endfor -%}
      </div>

      <div class="contact-form__actions">
        <button type="submit" class="contact-form__submit button">
          {{ section.settings.submit_label | default: 'Send Message' }}
        </button>
      </div>
    {%- endform -%}
  </div>
</section>

