{% comment %}
  Custom font loading snippet
  Include in layout/theme.liquid head section
  
  Usage: {% render 'custom-fonts' %}
{% endcomment %}

<link rel="preconnect" href="https://fonts.cdnfonts.com" crossorigin>
<link rel="preconnect" href="https://use.typekit.net" crossorigin>
<link href="https://fonts.cdnfonts.com/css/alte-haas-grotesk" rel="stylesheet">
<link rel="stylesheet" href="https://use.typekit.net/vci3tvq.css">

{% comment %} Preload critical fonts for performance {% endcomment %}
{%- comment -%}
  Uncomment and customize these preload links for your fonts:
  
  <link rel="preload" href="{{ 'roboto-regular.woff2' | asset_url }}" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="{{ 'roboto-bold.woff2' | asset_url }}" as="font" type="font/woff2" crossorigin>
{%- endcomment -%}

{% comment %} Font-face declarations {% endcomment %}
<style>
  @font-face {
    font-family: 'Druk Wide Bold Bold';
    src: local('Druk Wide Bold Bold'), url('{{ "DrukWideBold.woff" | asset_url }}') format('woff');
    font-style: normal;
    font-weight: 400;
    font-display: swap;
  }

  :root {
    --font-family-display: 'Druk Wide Bold Bold', sans-serif;
  }

  {%- comment -%}
    Customize these @font-face declarations for your project fonts:
    
    @font-face {
      font-family: 'Roboto';
      src: url('{{ "roboto-regular.woff2" | asset_url }}') format('woff2'),
           url('{{ "roboto-regular.woff" | asset_url }}') format('woff');
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
    
    @font-face {
      font-family: 'Roboto';
      src: url('{{ "roboto-bold.woff2" | asset_url }}') format('woff2'),
           url('{{ "roboto-bold.woff" | asset_url }}') format('woff');
      font-weight: 700;
      font-style: normal;
      font-display: swap;
    }
  {%- endcomment -%}
</style>