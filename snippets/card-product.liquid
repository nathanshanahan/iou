{% comment %}
  Renders a product card.
  Usage: {% render 'card-product', product: product %}
{% endcomment %}

{%- liquid
  assign ratio = 1
  if product.featured_media and section.settings.image_ratio == 'portrait'
    assign ratio = 0.8
  endif
-%}

<div class="card-product">
  <a href="{{ product.url }}" class="card-product__link">
    <div class="card-product__media" style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%">
      {%- if product.featured_media -%}
        {{
          product.featured_media
          | image_url: width: 600
          | image_tag:
            loading: 'lazy',
            widths: '200, 400, 600',
            sizes: '(min-width: 1200px) 300px, (min-width: 768px) 25vw, 50vw',
            alt: product.featured_media.alt | default: product.title
        }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'card-product__placeholder' }}
      {%- endif -%}
    </div>

    <div class="card-product__info">
      <h3 class="card-product__title">{{ product.title }}</h3>
      <p class="card-product__price">
        {{- product.price_min | money -}}
        {%- if product.price_varies %} &ndash; {{ product.price_max | money }}{% endif -%}
      </p>
    </div>
  </a>
</div>
